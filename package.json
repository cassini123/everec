{
  "name": "everec",
  "private": true,
  "type": "module",
  "workspaces": [
    "shared",
    "web/frontend",
    "web/backend",
    "desktop-client/ui"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=@everec/web-backend & npm run dev --workspace=@everec/web-frontend",
    "dev:desktop": "npm run dev --prefix desktop-client",
    "build:web": "npm run build --workspace=@everec/web-frontend",
    "build:vercel-api": "node scripts/build-vercel-api.mjs",
    "build:vercel": "npm run build:vercel-api && npm run build:web",
    "build:desktop": "npm run ui:build --prefix desktop-client"
  },
  "dependencies": {
    "@everec/shared": "*",
    "hono": "^4.7.10",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.5"
  }
}
