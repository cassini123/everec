{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install",
  "buildCommand": "npm run build:vercel-portal",
  "outputDirectory": "portal/dist",
  "framework": null,
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 30
    },
    "api/knowgo/index.js": {
      "memory": 1024,
      "maxDuration": 30
    },
    "api/prerector/index.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/knowgo/(.*)", "destination": "/api/knowgo" },
    { "source": "/api/prerector/(.*)", "destination": "/api/prerector" },
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/apps/simcut/(.*)", "destination": "/apps/simcut/index.html" },
    { "source": "/apps/desound/(.*)", "destination": "/apps/desound/index.html" },
    { "source": "/apps/knowgo/(.*)", "destination": "/apps/knowgo/index.html" },
    { "source": "/apps/prerector/(.*)", "destination": "/apps/prerector/index.html" },
    { "source": "/((?!api/|apps/).*)", "destination": "/index.html" }
  ]
}
