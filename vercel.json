{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --prefix simcut/web/frontend",
  "buildCommand": "npm run build --prefix simcut/web/frontend",
  "outputDirectory": "simcut/web/frontend/dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
