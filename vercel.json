{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --prefix simcut/apps/desktop/ui",
  "buildCommand": "npm run build --prefix simcut/apps/desktop/ui",
  "outputDirectory": "simcut/apps/desktop/ui/dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
